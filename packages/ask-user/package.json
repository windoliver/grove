{
  "name": "@grove/ask-user",
  "description": "Standalone MCP server that intercepts agent questions and routes them to an answering strategy",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "grove-ask-user": "./dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "biome check ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.78.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/bun": "1.3.9",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "zod": ">=3.25.0"
  }
}
